// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums para roles, géneros y estados
enum Role {
  ADMIN
  DOCTOR
  RECEPCIONISTA
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum EstadoCita {
  PROGRAMADA
  COMPLETADA
  CANCELADA
}

// Modelo User para autenticación básica
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  rol          Role     @default(DOCTOR)
  nombre       String

  // Relaciones inversas (1:N)
  historiasCreadas HistoriaClinica[]
  citasGestionadas Cita[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Modelo Paciente para datos personales
model Paciente {
  id               String   @id @default(uuid())
  nombre           String
  apellido         String
  fechaNacimiento  DateTime
  genero           Genero
  tipoSangre       String?
  contacto         String?
  alergias         String?
  antecedentes     String?
  estadoClinico    String?

  // Relaciones inversas (1:N)
  historiasClinicas HistoriaClinica[]
  citas            Cita[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Modelo HistoriaClinica para el registro de consultas
model HistoriaClinica {
  id              String   @id @default(uuid())
  fecha           DateTime @default(now())
  motivo          String
  sintomas        String
  diagnostico     String?
  planTratamiento String?

  // Signos vitales
  presion         String   // Ej: "120/80"
  pulso           Decimal  // Latidos por minuto
  temperatura     Decimal  // En grados Celsius
  peso            Decimal  // En kg

  // Relación con Paciente
  pacienteId      String
  paciente        Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  // Relación con Médico (User)
  // Usamos onDelete: Restrict por seguridad médica. No se puede eliminar un doctor si tiene historias clínicas creadas. (Se debería desactivar al usuario en su lugar)
  doctorId        String
  doctor          User     @relation(fields: [doctorId], references: [id], onDelete: Restrict)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Modelo Cita para gestión de agenda
model Cita {
  id         String     @id @default(uuid())
  fechaHora  DateTime
  motivo     String
  estado     EstadoCita @default(PROGRAMADA)

  // Relación con Paciente
  pacienteId String
  paciente   Paciente   @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  // Relación con Usuario que gestiona o atiende la cita
  // Usamos onDelete: Restrict para no perder el registro de quién agendó o a quién le pertenece la cita si el usuario se elimina.
  usuarioId  String
  usuario    User       @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}